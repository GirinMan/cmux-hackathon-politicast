# PolitiKAST 환경 변수 템플릿 — `cp .env.example .env` 후 채우기
# .env는 gitignored. NEVER commit secrets.

# ============================================================
# === LLM 모델 라우팅 (자체 호스팅 LiteLLM proxy 통일 게이트) ===
# ============================================================
# 모든 LLM 호출은 LITELLM_API_BASE 의 자체 호스팅 LiteLLM proxy 를 거친다.
# proxy 가 실제로 서비스하는 모델명을 그대로 사용 (예: EXAONE-4.0-1.2B).
# OpenAI-compatible v1 endpoint 이므로 model 에 ``openai/`` prefix 부착.
LITELLM_MODEL_VOTER_NORMAL=openai/EXAONE-4.0-1.2B
LITELLM_MODEL_VOTER_EDUCATED=openai/EXAONE-4.0-1.2B
LITELLM_MODEL_INTERVIEW=openai/EXAONE-4.0-1.2B
POLITIKAST_EDUCATED_CUTOFF=bachelor
LITELLM_MODEL=openai/EXAONE-4.0-1.2B
DEV_OVERRIDE_MODEL=openai/EXAONE-4.0-1.2B

# ============================================================
# === API Endpoint + Key (자체 호스팅 LiteLLM proxy) ===
# ============================================================
# proxy URL — 절대 코드/git 에 포함 금지. .env 만 SoT.
LITELLM_API_BASE=https://litellm.example.invalid/v1

# Provider 무관 generic 키 — LLMPool._collect_keys 가 provider env 미설정 시 fallback.
# proxy 가 sk- 토큰 자체로 인증하므로 한 풀로 충분.
LLM_API_KEYS=sk-REPLACE_WITH_ACTUAL_KEY

# (Optional) 다른 직접 endpoint 사용 시 — proxy 게이트와 동시 사용은 권장 X.
# OPENAI_API_KEYS=sk-proj-...
# ANTHROPIC_API_KEYS=sk-ant-...
# GEMINI_API_KEYS=AIzaSy...
# AZURE_API_KEYS=...
# AZURE_API_BASE=https://<resource>.openai.azure.com
# AZURE_API_VERSION=2024-10-21
# GROQ_API_KEYS=gsk_...
# OPENROUTER_API_KEYS=sk-or-...

# ============================================================
# === LLM 풀 ===
# ============================================================
LLM_PER_KEY_RPM=500
LLM_COST_THRESHOLD_OPENAI_USD=50

# Voter agent sampling temperature (default 1.0 — JSON 출력 안정성 우선).
# 다양성은 prompt few-shot + candidate shuffle 로 확보. 모델별 fine-tune 시만 변경.
POLITIKAST_VOTER_TEMPERATURE=1.0

# Vertex AI / Bedrock — IAM 기반 (proxy 미사용 시)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# ============================================================
# === Backend / Env mode ===
# ============================================================
POLITIKAST_LLM_BACKEND=auto
POLITIKAST_ENV=dev

# ============================================================
# === PolitiKAST runtime flags (sim/election_env.py) ===
# ============================================================
# LLM 응답 캐시 활성화 (1=on / 0=off). 검증용 클린런에서는 0으로.
POLITIKAST_LLM_CACHE=1
# 시나리오 timestep 수 (정수, 기본 4). 빠른 검증은 2.
POLITIKAST_TIMESTEPS=4
# 활성 feature flag, comma-separated. 옵션: bandwagon,underdog,second_order,kg_retrieval,cohort_prior
POLITIKAST_FEATURES=bandwagon,underdog,second_order,kg_retrieval,cohort_prior
# 마지막 timestep 직전에 외부 poll 결과를 voter에게 노출할지 (1=on / 0=off, 기본 0)
POLITIKAST_FINAL_POLL_FEEDBACK=0
# Held-out poll target을 voter 프롬프트에 노출 (ablation 전용). 기본 0=hidden.
POLITIKAST_POLL_TARGETS_VISIBLE_TO_AGENTS=0
# 검증 cutoff timestamp (ISO8601, 시점 이후 사실은 firewall 차단). 빈 값이면 scenario 기본 사용.
POLITIKAST_VALIDATION_CUTOFF_TS=2026-04-26T00:00:00+09:00
# 정책 버전 라벨 — result.meta 에 박제된다.
POLITIKAST_POLICY_VERSION=v1
# 5 region 동시 실행 시 region 단위 concurrency
POLITIKAST_CONCURRENCY=2
# KG firewall strict mode (1=on / 0=off, 기본 1). 0이면 ts 누락 노드도 통과 (dev only).
POLITIKAST_KG_STRICT=1
# Registry 디렉토리 override. 미설정 시 _workspace/data/registries/ 사용.
# POLITIKAST_REGISTRY_DIR=/abs/path/to/custom/registries

# ============================================================
# === Phase 4 cutover — Postgres + Neo4j ===
# ============================================================
# Postgres DSN — async (asyncpg) 형태가 default. sync 도구 (alembic / migration)
# 는 자동으로 psycopg2 형태로 변환된다.
POLITIKAST_PG_DSN=postgresql+asyncpg://politikast:politikast@localhost:5433/politikast
# 12-factor 표준. POLITIKAST_PG_DSN 미설정 시 fallback.
# DATABASE_URL=postgresql://politikast:politikast@localhost:5433/politikast

# docker-compose 측 PG 변수
POSTGRES_USER=politikast
POSTGRES_PASSWORD=politikast
POSTGRES_DB=politikast
POSTGRES_PORT=5433

# Backend 가 PG 모드로 동작하도록 강제 (settings.enable_postgres)
POLITIKAST_API_ENABLE_POSTGRES=1
# 시도 끄려면 명시:
# POLITIKAST_DB_BACKEND=duckdb

# Neo4j (kg-neo4j stream)
NEO4J_AUTH=neo4j/politikast-dev
NEO4J_PASSWORD=politikast-dev
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
POLITIKAST_API_NEO4J_URI=bolt://localhost:7687
POLITIKAST_API_NEO4J_USER=neo4j
POLITIKAST_API_NEO4J_PASSWORD=politikast-dev

# Backend / Frontend 포트
BACKEND_PORT=8080
FRONTEND_PORT=5173

# ============================================================
# === Phase 4 Admin auth ===
# ============================================================
# 관리자 시드 — 비밀번호가 있으면 첫 부팅 시 admin 계정을 1회 생성한다.
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-strong
# JWT 알고리즘 (HS256 default; RS256 사용 시 두 PEM 환경변수 추가).
POLITIKAST_API_ADMIN_JWT_SECRET=dev-admin-jwt-secret-change-me
POLITIKAST_API_ADMIN_JWT_ALG=HS256
# RS256 운영 시:
# ADMIN_JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n..."
# ADMIN_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n..."

# Internal service token — 시뮬레이터 → /internal/* 업로드용.
POLITIKAST_API_INTERNAL_SERVICE_TOKEN=dev-internal-token-change-me

# Frontend → backend base URL (vite dev 만 사용; nginx 운영 시 비워둔다).
VITE_API_BASE_URL=http://localhost:8080

# ============================================================
# === 데이터 / UI ===
# ============================================================
NEMOTRON_PARQUET_DIR=/absolute/path/to/Nemotron-Personas-Korea/data
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

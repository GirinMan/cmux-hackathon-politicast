# PolitiKAST 환경 변수 템플릿 — `cp .env.example .env` 후 채우기
# .env는 gitignored. NEVER commit secrets.

# ============================================================
# === LLM 모델 라우팅 (persona-conditional) ===
# ============================================================
LITELLM_MODEL_VOTER_NORMAL=gpt-5.4-nano
LITELLM_MODEL_VOTER_EDUCATED=gpt-5.4-mini
LITELLM_MODEL_INTERVIEW=claude-sonnet-4-6
POLITIKAST_EDUCATED_CUTOFF=bachelor
LITELLM_MODEL=gpt-5.4-nano

# ============================================================
# === API Keys ===
# ============================================================
OPENAI_API_KEYS=sk-proj-...
ANTHROPIC_API_KEYS=sk-ant-...
GEMINI_API_KEYS=AIzaSy...
DEV_OVERRIDE_MODEL=gemini/gemini-3.1-flash-lite-preview
# AZURE_API_KEYS=...
# AZURE_API_BASE=https://<resource>.openai.azure.com
# AZURE_API_VERSION=2024-10-21
# GROQ_API_KEYS=gsk_...
# OPENROUTER_API_KEYS=sk-or-...

# Generic fallback
# LLM_API_KEYS=key1,key2

# ============================================================
# === LLM 풀 ===
# ============================================================
LLM_PER_KEY_RPM=500
LLM_COST_THRESHOLD_OPENAI_USD=50
LLM_COST_THRESHOLD_ANTHROPIC_USD=20
LLM_COST_THRESHOLD_GEMINI_USD=5
# LITELLM_API_BASE=https://...

# Vertex AI / Bedrock — IAM 기반
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# ============================================================
# === Backend / Env mode ===
# ============================================================
POLITIKAST_LLM_BACKEND=auto
POLITIKAST_ENV=dev

# ============================================================
# === Legacy ===
# ============================================================
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ============================================================
# === 데이터 / UI ===
# ============================================================
NEMOTRON_PARQUET_DIR=/absolute/path/to/Nemotron-Personas-Korea/data
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

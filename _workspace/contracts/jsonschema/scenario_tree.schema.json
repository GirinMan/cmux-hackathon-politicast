{
  "$defs": {
    "BeamConfig": {
      "additionalProperties": false,
      "description": "Parameters fed into `BeamSearch.expand()` — frozen on the artifact.",
      "properties": {
        "beam_width": {
          "description": "top-W kept per depth",
          "minimum": 1,
          "title": "Beam Width",
          "type": "integer"
        },
        "beam_depth": {
          "description": "max depth (root excluded)",
          "minimum": 1,
          "title": "Beam Depth",
          "type": "integer"
        },
        "k_propose": {
          "default": 3,
          "description": "events proposed per leaf",
          "minimum": 1,
          "title": "K Propose",
          "type": "integer"
        },
        "proposer": {
          "default": "composite",
          "enum": [
            "kg",
            "llm",
            "custom",
            "composite"
          ],
          "title": "Proposer",
          "type": "string"
        },
        "seed": {
          "default": 11,
          "title": "Seed",
          "type": "integer"
        },
        "sample_n": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sample N"
        },
        "timesteps": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timesteps"
        },
        "strict_temporal": {
          "default": true,
          "title": "Strict Temporal",
          "type": "boolean"
        }
      },
      "required": [
        "beam_width",
        "beam_depth"
      ],
      "title": "BeamConfig",
      "type": "object"
    },
    "BeamEvent": {
      "additionalProperties": false,
      "description": "Discrete event proposed by an `EventProposer`.\n\nSee module docstring for the official `candidate_patches` / `event_patches`\nshape contract — declarative (primary) and imperative (legacy) are both\naccepted; the splicer routes them appropriately.",
      "properties": {
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "source": {
          "enum": [
            "kg_confirmed",
            "llm_hypothetical",
            "custom"
          ],
          "title": "Source",
          "type": "string"
        },
        "occurs_at": {
          "format": "date-time",
          "title": "Occurs At",
          "type": "string"
        },
        "description": {
          "description": "한국어 라벨, Sankey 노드에 표시",
          "title": "Description",
          "type": "string"
        },
        "candidate_patches": {
          "description": "Declarative ({candidate_id, boost|drop_out|reason, …}) is the primary form. Imperative ({op, candidate_id, fields|candidate}) is also supported for run_counterfactual interop.",
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Candidate Patches",
          "type": "array"
        },
        "event_patches": {
          "description": "Declarative ({issue, salience, …}) is the primary form. Imperative ({op:'add'|'remove', event:{event_id,…}}) is also supported for run_counterfactual interop.",
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Event Patches",
          "type": "array"
        },
        "prior_p": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Prior P",
          "type": "number"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "event_id",
        "source",
        "occurs_at",
        "description",
        "prior_p"
      ],
      "title": "BeamEvent",
      "type": "object"
    },
    "BeamNode": {
      "additionalProperties": false,
      "description": "One node in the scenario tree — root or expanded leaf.\n\nRoot has `parent_id=None` and `event=None` — it represents the as_of\nstate with frozen calibrated params + KG snapshot at cutoff=as_of.",
      "properties": {
        "node_id": {
          "title": "Node Id",
          "type": "string"
        },
        "parent_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Id"
        },
        "depth": {
          "minimum": 0,
          "title": "Depth",
          "type": "integer"
        },
        "event": {
          "anyOf": [
            {
              "$ref": "#/$defs/BeamEvent"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "cumulative_p": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Cumulative P",
          "type": "number"
        },
        "sim_result_ref": {
          "description": "_workspace/snapshots/results/{scenario_id}.json relative path; stored so frontend can drill down to ScenarioResult on click.",
          "title": "Sim Result Ref",
          "type": "string"
        },
        "leader_candidate_id": {
          "title": "Leader Candidate Id",
          "type": "string"
        },
        "predicted_shares": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Predicted Shares",
          "type": "object"
        },
        "children": {
          "items": {
            "type": "string"
          },
          "title": "Children",
          "type": "array"
        }
      },
      "required": [
        "node_id",
        "depth",
        "cumulative_p",
        "sim_result_ref",
        "leader_candidate_id"
      ],
      "title": "BeamNode",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Top-level beam-search artifact — written under\n`_workspace/snapshots/scenario_trees/{tree_id}.json`.",
  "properties": {
    "tree_id": {
      "title": "Tree Id",
      "type": "string"
    },
    "region_id": {
      "title": "Region Id",
      "type": "string"
    },
    "contest_id": {
      "title": "Contest Id",
      "type": "string"
    },
    "as_of": {
      "format": "date",
      "title": "As Of",
      "type": "string"
    },
    "election_date": {
      "format": "date",
      "title": "Election Date",
      "type": "string"
    },
    "config": {
      "$ref": "#/$defs/BeamConfig"
    },
    "root_id": {
      "title": "Root Id",
      "type": "string"
    },
    "nodes": {
      "additionalProperties": {
        "$ref": "#/$defs/BeamNode"
      },
      "title": "Nodes",
      "type": "object"
    },
    "mlflow_run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Mlflow Run Id"
    },
    "built_at": {
      "format": "date-time",
      "title": "Built At",
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    }
  },
  "required": [
    "tree_id",
    "region_id",
    "contest_id",
    "as_of",
    "election_date",
    "config",
    "root_id",
    "nodes"
  ],
  "title": "ScenarioTree",
  "type": "object"
}